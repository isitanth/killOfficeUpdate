#!/bin/zsh
#
# Git pre-commit hook — runs unit tests before allowing a commit.
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#

echo "Running tests before commit..."

PROJECT_DIR="$(git rev-parse --show-toplevel)/KillOfficeUpdateApp"

xcodebuild test \
    -project "$PROJECT_DIR/KillOfficeUpdateApp.xcodeproj" \
    -scheme KillOfficeUpdateAppTests \
    -destination 'platform=macOS' \
    -quiet 2>&1

if [ $? -ne 0 ]; then
    echo ""
    echo "COMMIT BLOCKED: Tests failed. Fix the failures before committing."
    exit 1
fi

echo "All tests passed."
exit 0
